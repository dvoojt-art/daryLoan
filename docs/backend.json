
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Basic profile information for DaryLoan users.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "member"],
          "description": "The security role of the user."
        }
      },
      "required": ["email", "role"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User-specific settings and role assignment."
    }
  }
}

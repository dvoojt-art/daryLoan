{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive profile information for DaryLoan users.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "member"],
          "description": "The security role of the user."
        },
        "name": {
          "type": "string",
          "description": "The full name of the member."
        },
        "status": {
          "type": "string",
          "enum": ["active", "pending"],
          "description": "The current account status."
        },
        "shares": {
          "type": "number",
          "description": "Total value of community shares owned."
        },
        "profit": {
          "type": "number",
          "description": "Total profit distributed to this member."
        },
        "joinDate": {
          "type": "string",
          "format": "date",
          "description": "The date the member joined the community."
        },
        "totalContributions": {
          "type": "number",
          "description": "Cumulative historical contributions."
        }
      },
      "required": ["email", "role", "name", "status"]
    },
    "Loan": {
      "title": "Loan",
      "description": "A loan request and its current status.",
      "type": "object",
      "properties": {
        "memberId": {
          "type": "string",
          "description": "The UID of the member who owns this account."
        },
        "comakerId": {
          "type": "string",
          "description": "The UID of the member acting as a comaker/guarantor."
        },
        "loanerName": {
          "type": "string",
          "description": "The display name of the person receiving the loan."
        },
        "amount": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "repaid", "overdue"]
        },
        "requestDate": {
          "type": "string",
          "format": "date"
        },
        "dueDate": {
          "type": "string",
          "format": "date"
        },
        "interestRate": {
          "type": "number"
        },
        "termMonths": {
          "type": "number"
        },
        "purpose": {
          "type": "string"
        },
        "adminNote": {
          "type": "string"
        }
      },
      "required": ["memberId", "amount", "status", "requestDate"]
    },
    "Contribution": {
      "title": "Contribution",
      "description": "A record of a member's financial contribution to the pool.",
      "type": "object",
      "properties": {
        "memberId": {
          "type": "string",
          "description": "The UID of the contributing member."
        },
        "amount": {
          "type": "number",
          "description": "The amount contributed."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of contribution."
        }
      },
      "required": ["memberId", "amount", "date"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User-specific settings and role assignment."
    },
    "/loans/{loanId}": {
      "schema": {
        "$ref": "#/entities/Loan"
      },
      "description": "Central collection of community loan records."
    },
    "/contributions/{contributionId}": {
      "schema": {
        "$ref": "#/entities/Contribution"
      },
      "description": "Collection of member savings and contributions."
    }
  }
}